# Normalize line endings: LF in the repo, auto on checkout.
* text=auto

# Source and text files always LF.
*.cs      text eol=lf
*.csproj  text eol=lf
*.slnx    text eol=lf
*.props   text eol=lf
*.md      text eol=lf
*.yml     text eol=lf
*.json    text eol=lf
*.surql   text eol=lf

# Binaries.
*.png binary
*.snk binary
